{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": "Sprint Race Winners (Drivers)",
    "width": 800,
    "height": 600,
    "data": {
        "url": "../f1-data/sprint_results.csv",
        "format": {"type": "csv"}
    },

    "transform": [
        {
            "lookup": "driverId",
            "from": {
                "data": {"url": "../f1-data/drivers.csv"},
                "key": "driverId",
                "fields": ["forename", "surname"]
            },
            "as": ["driverForename", "driverSurname"]
        },
        {
            "calculate": "datum.driverForename + ' ' + datum.driverSurname",
            "as": "driverName"
        },
        {
            "filter": "datum.positionOrder == 1"
        },
        {
            "aggregate": [{
                "op": "sum",
                "field": "positionOrder",
                "as": "totalWins"
            }],
            "groupby": ["driverName"]
        }

    ],
    "mark": {"type": "bar"},
    "encoding": {
        "y": {
            "field": "driverName",
            "type": "nominal",
            "sort": {
                "field": "totalWins",
                "op": "sum",
                "order": "descending"
            },
            "title": "Driver Name"
        },
        "x": {
            "field": "totalWins",
            "type": "quantitative",
            "title": "Total Sprint Race wins"

        },
        "tooltip": [
            {
                "field": "totalWins",
                "title": "Total Sprint Race wins"
            }
        ]
    }

    
}