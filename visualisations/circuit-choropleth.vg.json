{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": "F1 Circuits around the globe",
    "width": "container",
    "height": "container",
    "autosize": {"type": "fit", "contains": "padding"},
    "background": "transparent",
    "projection": {
        "type": "equalEarth"
    },
    "layer": [
        {
            "data": {
                "url": "../f1-data/ne_110m.json",
                "format": {
                    "type": "topojson",
                    "feature": "ne_110m_admin_0_countries"
                }
            },
            "mark": {
                "type": "geoshape",
                "fill": "white", 
                "stroke": "lightgray"
            }
        },
        {
            "data": {
                "url": "../f1-data/ne_110m.json",
                "format": {
                    "type": "topojson",
                    "feature": "ne_110m_admin_0_countries"
                }
            },
            "transform": [
                {
                    "lookup": "properties.NAME",
                    "from": {
                        "data": {
                            "url": "../f1-data/country_counts.csv"
                        },
                        "key": "country",
                        "fields": [
                            "country", "circuit_count"
                        ]
                    }
                }
            ],
            "mark": {
                "type": "geoshape"
            },
            "encoding": {
                "color": {
                    "field": "circuit_count",
                    "type": "quantitative"
                },
                "tooltip": [
                    {
                        "field": "country",
                        "title": "Country"
                    },
                    {
                        "field": "circuit_count",
                        "title": "Circuit Count"
                    }
                ]
            }
        }
    ]
}