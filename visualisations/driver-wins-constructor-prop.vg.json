{
    "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
    "title": {
        "text": "Proportion of Wins per Team",
        "anchor": "start"
    },
    "width": "container",
    "height": "container",
    "autosize": {
        "type": "fit"
    },
    "background": "transparent",
    "data": {
        "url": "./f1-data/results.csv",
        "format": {
            "type": "csv"
        }
    },
    "transform": [
        {
            "lookup": "driverId",
            "from": {
                "data": {
                    "url": "./f1-data/drivers.csv"
                },
                "key": "driverId",
                "fields": [
                    "forename",
                    "surname"
                ]
            },
            "as": [
                "driverForename",
                "driverSurname"
            ]
        },
        {
            "calculate": "datum.driverForename + ' ' + datum.driverSurname",
            "as": "driverName"
        },
        {
            "filter": "datum.driverId == '1'"
        },
        {
            "lookup": "constructorId",
            "from": {
                "data": {
                    "url": "./f1-data/constructors.csv"
                },
                "key": "constructorId",
                "fields": [
                    "name"
                ]
            },
            "as": [
                "Team Name"
            ]
        },
        {
            "filter": "datum.positionOrder == 1"
        },
        {
            "aggregate": [
                {
                    "op": "count",
                    "field": "raceId",
                    "as": "totalWins"
                }
            ],
            "groupby": [
                "Team Name"
            ]
        }
    ],
    "mark": {
        "type": "arc",
        "outerRadius": {
            "expr": "min(width, height) / 2"
        },
        "innerRadius": {
            "expr": "min(width, height) / 4"
        }
    },
    "encoding": {
        "theta": {
            "field": "totalWins",
            "type": "quantitative"
        },
        "color": {
            "field": "Team Name",
            "type": "nominal",
            "scale": {
                "domain": [
                    "McLaren",
                    "Mercedes"
                ],
                "range": [
                    "#E8761C",
                    "#78B4D6"
                ]
            }
        },
        "tooltip": [
            {
                "field": "Team Name",
                "type": "nominal",
                "title": "Team"
            },
            {
                "field": "totalWins",
                "type": "quantitative",
                "title": "Wins with Team"
            }
        ]
    }
}
